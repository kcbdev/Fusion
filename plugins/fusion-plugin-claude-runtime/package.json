{
  "name": "@fusion-plugin-examples/claude-runtime",
  "version": "0.1.6-beta.0",
  "type": "module",
  "description": "Claude Code runtime plugin for Fusion (ACP bridge)",
  "keywords": [
    "fusion-plugin",
    "claude",
    "acp",
    "agent-client-protocol",
    "runtime"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./probe": {
      "types": "./src/probe.ts",
      "source": "./src/probe.ts",
      "import": "./dist/probe.js"
    }
  },
  "private": true,
  "scripts": {
    "build": "tsc && node -e \"require('node:fs').copyFileSync('src/mcp-schema-server.cjs','dist/mcp-schema-server.cjs')\"",
    "test": "vitest run --silent=passed-only --reporter=dot"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.24.0",
    "@fusion/core": "workspace:*",
    "@fusion/plugin-sdk": "workspace:*",
    "claude-code-cli-acp": "0.1.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
